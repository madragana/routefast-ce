{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Model Decision",
  "type": "object",
  "required": ["action", "confidence", "reason", "evidence", "rollback_ttl_seconds", "peer_corroboration_required"],
  "properties": {
    "action": {
      "type": "string",
      "enum": [
        "EXPLAIN_ONLY",
        "BLOCK_SOURCE",
        "RATE_LIMIT_SOURCE",
        "LOWER_LOCAL_PREF",
        "WITHDRAW_PREFIX_TEMPORARY",
        "REROUTE_PREFIX",
        "SHIFT_SERVICE_CLASS_TO_BEARER",
        "QUARANTINE_VRF",
        "REQUEST_PEER_ASSIST",
        "REQUEST_CORROBORATION"
      ]
    },
    "target": {"type": "string"},
    "constraints": {"type": "object"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "reason": {"type": "string"},
    "evidence": {"type": "array", "items": {"type": "string"}},
    "impact_estimate": {"type": "string", "enum": ["low", "medium", "high"]},
    "rollback_ttl_seconds": {"type": "integer", "minimum": 0, "maximum": 3600},
    "peer_corroboration_required": {"type": "boolean"}
  }
}
